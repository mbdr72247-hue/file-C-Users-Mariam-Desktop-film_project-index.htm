<!DOCTYPE html>
<html>
<head>
    <title>أفلامي المفضلة</title>

    <style>
       body {
    font-family: Arial;
    background-image: url("bg.jpg");
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    color: white;
    text-align: center;
}

        h1 {

           color: gold;
        }

        .card {
                  background-color: rgba(0, 0, 0, 0.7);
            background-color: #222;
            width: 250px;
            display: inline-block;
            margin: 15px;
            padding: 10px;
            border-radius: 15px;
            transition: 0.3s;
        }

        .card:hover {
            transform: scale(1.05);
        }

        img {
            width: 100%;
            height: 300px;
            object-fit: cover;
            border-radius: 10px;
        }
    </style>

</head>

<body>

<h1>🎬 أفلامي المفضلة</h1>

<!-- فيلم 1 -->
